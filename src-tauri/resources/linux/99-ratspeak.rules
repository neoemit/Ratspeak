# udev rules for USB-Serial radios used by Ratspeak (RNode and friends).
#
# VID list mirrors `KNOWN_VIDS` in
# `rsReticulum/crates/rns-interface/src/android_usb.rs` — keep in sync.
#
# MODE="0666" makes the device world-RW so a desktop user-space app can open
# /dev/ttyUSB* / /dev/ttyACM* without being in the dialout/uucp group. Acceptable
# trade-off for a single-user desktop deployment; multi-user / kiosk operators
# may prefer GROUP="plugdev" + manual usermod.
#
# Install:
#   sudo cp 99-ratspeak.rules /etc/udev/rules.d/
#   sudo udevadm control --reload && sudo udevadm trigger
#
# Uninstall:
#   sudo rm /etc/udev/rules.d/99-ratspeak.rules && sudo udevadm control --reload

# FTDI (FT232 / FT2232 / FT4232 etc.)
SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", MODE="0666", TAG+="uaccess"

# Silicon Labs CP210x (CP2102 / CP2104) — most RNode hardware
SUBSYSTEM=="tty", ATTRS{idVendor}=="10c4", MODE="0666", TAG+="uaccess"

# WCH CH340 / CH341
SUBSYSTEM=="tty", ATTRS{idVendor}=="1a86", MODE="0666", TAG+="uaccess"

# CDC-ACM (Netchip and other generic CDC-ACM devices)
SUBSYSTEM=="tty", ATTRS{idVendor}=="0525", MODE="0666", TAG+="uaccess"

# Raspberry Pi Pico / RP2040
SUBSYSTEM=="tty", ATTRS{idVendor}=="2e8a", MODE="0666", TAG+="uaccess"

# Espressif ESP32-S3 (native USB)
SUBSYSTEM=="tty", ATTRS{idVendor}=="303a", MODE="0666", TAG+="uaccess"

# Adafruit boards
SUBSYSTEM=="tty", ATTRS{idVendor}=="239a", MODE="0666", TAG+="uaccess"

# Nordic Semiconductor nRF52840
SUBSYSTEM=="tty", ATTRS{idVendor}=="1915", MODE="0666", TAG+="uaccess"
