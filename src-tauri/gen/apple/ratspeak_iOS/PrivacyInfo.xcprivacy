<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      iOS Privacy Manifest (Apple ITMS-91053).

      Required-reason API declarations below cover:
        - Rust standard library on Apple platforms (std::time, std::fs,
          std::env). These transitively touch UserDefaults, mach_absolute_time
          (SystemBootTime), file timestamps, and disk-space APIs regardless of
          whether Ratspeak calls them explicitly.
        - Tauri v2 fs and notification plugins.
        - rusqlite / SQLite file operations.

      Ratspeak does not transmit any off-device telemetry, does not perform
      cross-app tracking, and does not embed any ad/analytics SDK. Mesh
      messages are end-to-end encrypted and only flow between peers; no
      backend owned by the Ratspeak developer collects user data.
    -->

    <key>NSPrivacyTracking</key>
    <false/>

    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <key>NSPrivacyCollectedDataTypes</key>
    <array/>

    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <dict>
            <!-- std::time::Instant uses mach_absolute_time on Apple platforms. -->
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategorySystemBootTime</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>35F9.1</string>
            </array>
        </dict>
        <dict>
            <!--
              std::fs metadata, SQLite file stat, Tauri fs plugin file reads.
              Reason C617.1: "display timestamps to the user inside the app"
              — surfaced in the Messages and Settings views.
            -->
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>C617.1</string>
            </array>
        </dict>
        <dict>
            <!--
              SQLite pragma + std::fs space checks on the dashboard DB.
              Reason E174.1: "write files when space is available".
            -->
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryDiskSpace</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>E174.1</string>
            </array>
        </dict>
        <dict>
            <!--
              Reason CA92.1: "access info from same app" — covers the
              Tauri window-state plugin and any transitive UserDefaults use
              by Rust/Objective-C bridging code inside the same bundle.
            -->
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>CA92.1</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
